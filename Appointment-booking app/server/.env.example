# ────────────────────────────────────
# Appointment Book — Server Config
# ────────────────────────────────────
# Copy this file to .env and fill in your values

# Email: Resend API
# Sign up at https://resend.com (free tier: 100 emails/day)
# Then create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Email: verified sender address
# Must be a verified domain in your Resend account
FROM_EMAIL=noreply@appointmentbook.com

# App URL used in email links
APP_URL=http://localhost:5173

# Server port
PORT=3001

# JWT: secret key for signing authentication tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# CORS: comma-separated allowed origins for production
# Leave empty to allow localhost origins for development
# Example: https://app.myapp.com,https://admin.myapp.com
CORS_ORIGINS=
