# ─── Database ──────────────────────────────────
# PostgreSQL connection string
# For local Docker: postgres://postgres:postgres@localhost:5432/appointmentbook
# For Railway: auto-provided as DATABASE_URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/appointmentbook

# ─── Authentication ────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-string

# ─── Email (Resend) ────────────────────────────
# Get your API key at https://resend.com
# Leave empty for dev mode (emails logged to console)
RESEND_API_KEY=
FROM_EMAIL=noreply@appointmentbook.com
APP_URL=http://localhost:5173

# ─── Server ────────────────────────────────────
PORT=3001

# ─── Scheduler ─────────────────────────────────
# DISABLE_SCHEDULER=true
# REMINDER_CHECK_INTERVAL=5
# REMINDER_HOURS_BEFORE=24
# REMINDER_WINDOW_MINUTES=120

# ─── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
# Default: localhost dev ports
# CORS_ORIGINS=https://myapp.com,https://www.myapp.com
